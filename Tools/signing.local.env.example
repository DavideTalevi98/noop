# Local Apple signing — COPY to signing.local.env (gitignored) and fill in.
# Never commit signing.local.env.
#
# Usage:
#   cp Tools/signing.local.env.example signing.local.env
#   # edit signing.local.env
#   ./Tools/apply-local-signing.sh
#   xcodegen generate

DEVELOPMENT_TEAM=
BUNDLE_PREFIX=com.yourdomain
APP_GROUP_ID=group.com.yourdomain.noop

# Optional — for Tools/install-noop-ios-watch.sh
# IPHONE_UDID=
# WATCH_UDID=
